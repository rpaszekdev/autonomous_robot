# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Google AI Studio API key for Gemini Live
GOOGLE_API_KEY=

# Gemini Live model ID (bidiGenerateContent-capable).
# Verified-working options (as of 2026-04):
#   gemini-3.1-flash-live-preview
#   gemini-2.5-flash-native-audio-latest
GEMINI_MODEL=gemini-3.1-flash-live-preview

# Force simulate mode (mock camera, motors, GPIO). 1 = on, 0 = off (auto-detect).
SIMULATE=0

# Session cost guardrails
MAX_SESSION_SECONDS=120
MAX_SESSIONS_PER_HOUR=30

# Optional audio device overrides (leave empty for system default)
SD_INPUT_DEVICE=
SD_OUTPUT_DEVICE=
